{
  "name": "linnea-desktop-pet",
  "productName": "Linnea",
  "version": "1.0.2",
  "private": true,
  "description": "Windows desktop pet with chat, automatic todo capture, and reminders.",
  "main": "dist-electron/electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on dist-electron/electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 DESKTOP_PET_TRANSPARENT=1 electron .\"",
    "dev:solid": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on dist-electron/electron/main/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "pack:win": "npm run build && electron-builder --win --x64 --dir",
    "dist:win": "npm run build && electron-builder --win --x64",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "build": {
    "appId": "com.local.linnea",
    "productName": "Linnea",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/afterPack.cjs",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/preload.cjs",
      "src/assets/app/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/app/linnea-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "src/assets/app/linnea-icon.ico",
      "uninstallerIcon": "src/assets/app/linnea-icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Linnea"
    }
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "openai": "^6.8.1",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.2",
    "wait-on": "^8.0.1"
  }
}
